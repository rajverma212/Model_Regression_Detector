{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": ["src/**", "data/seed.db", "datasets/**", "prompts/**", "config/**"]
      }
    }
  ],
  "routes": [{ "src": "/(.*)", "dest": "api/index.py" }]
}
